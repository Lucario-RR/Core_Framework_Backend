# PostgreSQL connection string used by sqlx and startup migrations.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/core_framework_backend

# IP address and port the axum HTTP server binds to.
BIND_ADDR=127.0.0.1:11451

# Public base URL used when generating links and external-facing URLs.
APP_BASE_URL=http://localhost:11451

# Secret key used to sign JWT access tokens. Replace this in every environment.
JWT_SECRET=replace-me-with-a-long-random-secret

# Whether auth cookies are marked Secure. Use true behind HTTPS.
COOKIE_SECURE=false

# Browser origins allowed to make credentialed API requests.
CORS_ALLOWED_ORIGINS=http://localhost:11451,http://localhost:5173,http://127.0.0.1:5173

# Allows first-admin bootstrap registration when the database setting also permits it.
PUBLIC_ADMIN_BOOTSTRAP_ENABLED=true

# Local directory for development file uploads and private download storage.
UPLOAD_DIR=storage

# Access token lifetime in seconds.
ACCESS_TOKEN_TTL_SECONDS=900

# Refresh token/session cookie lifetime in seconds.
REFRESH_TOKEN_TTL_SECONDS=2592000

# Password reset challenge lifetime in seconds.
PASSWORD_RESET_TTL_SECONDS=3600

# Email verification challenge lifetime in seconds.
EMAIL_VERIFICATION_TTL_SECONDS=86400

# Issuer label shown in authenticator apps for TOTP MFA.
TOTP_ISSUER=CoreFrameworkBackend

# Directory where the local backend debug log is written.
LOG_DIR=logs

# Rust tracing filter. Keep app logs at debug and dependency logs at info by default.
RUST_LOG=info,core_framework_backend=debug
